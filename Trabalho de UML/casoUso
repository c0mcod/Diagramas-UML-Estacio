@startuml

left to right direction
skinparam packageStyle rectangle

:Aluno: as aln
:Administração: as adm
:Secretaria: as sec
:Professor: as prof
:Coordenação: as coord

package Instituição {
    (Manter cadastros) as mc
    (Cadastrar usuário) as cu
    (Cadastrar aluno) as ca
    (Cadastrar professor) as cp
    (Cadastro de disciplinas) as cd
    (Cadastro de turmas) as ct
    (Gerar relatórios) as gr
    (Notificar alunos) as na
}

package AlunoInterface {
    (Registrar solicitação) as rs
    (Anexar documento) as anxDoc
    (Acompanhar solicitação) as acomp
}

package SecretariaInterface {
    (Validar documentação) as validDoc
    (Encaminhar solicitação) as encSol
}

package CoordenacaoInterface {
    (Analisar solicitação) as analise
    (Deferir solicitação) as aprovSol
    (Indeferir solicitação) as reprSol
}

package ProfessorInterface {
    (Responder solicitação) as resSol
}


adm --> mc
adm --> gr

sec --> validDoc
sec --> encSol
sec --> na
sec --> gr

coord --> cd
coord --> ct
coord --> analise
coord --> na
coord --> gr

prof --> resSol
prof --> gr

aln --> rs
aln --> anxDoc
aln --> acomp

ca -|> cu
cp -|> cu

cd -|> mc
ct -|> mc
cu -|> mc


encSol ..> validDoc : <<include>>

anxDoc ..> rs : <<extend>>

aprovSol ..> analise : <<extend>>
reprSol ..> analise : <<extend>>

@enduml
