@startuml

left to right direction
skinparam packageStyle rectangle
skinparam packagePadding 20
skinparam nodesep 60
skinparam ranksep 80

' ──────────── ATORES ────────────
:Aluno:         as aln
:Professor:     as prof
:Secretaria:    as sec
:Coordenação:   as coord
:Administração: as adm

' ──────────── PACOTES ────────────

package "Administração" {
    (Manter cadastros)        as mc
    (Cadastrar usuário)       as cu
    (Cadastrar aluno)         as ca
    (Cadastrar professor)     as cp
    (Cadastro de disciplinas) as cd
    (Cadastro de turmas)      as ct
    (Gerar relatórios)        as gr
}

package "Secretaria" {
    (Validar documentação)   as validDoc
    (Encaminhar solicitação) as encSol
    (Notificar alunos)       as na
}

package "Coordenação" {
    (Analisar solicitação)  as analise
    (Deferir solicitação)   as aprovSol
    (Indeferir solicitação) as reprSol
}

package "Professor" {
    (Responder solicitação) as resSol
    (Realizar check-in)     as checkin
}

package "Aluno" {
    (Registrar solicitação)          as rs
    (Acompanhar solicitação)         as acomp
    (Selecionar meio de notificação) as smn
    (Anexar documento)               as anxDoc
}

package "Comunicação" {
    (Chat de turma)                as chat
    (Grupo gerado automaticamente) as grupo
}

' ──────────── ASSOCIAÇÕES ATOR → CASO DE USO ────────────

adm   --> mc
adm   --> gr

sec   --> encSol
sec   --> validDoc
sec   --> na

coord --> analise
coord --> cd
coord --> ct
coord --> gr

prof  --> resSol
prof  --> checkin

aln   --> rs
aln   --> acomp
aln   --> smn
aln   --> chat

' ──────────── HERANÇAS ────────────

ca -|> cu
cp -|> cu
cu -|> mc
cd -|> mc
ct -|> mc

' ──────────── INCLUDE / EXTEND ────────────

encSol   ..> validDoc : <<include>>
anxDoc   ..> rs       : <<extend>>
aprovSol ..> analise  : <<extend>>
reprSol  ..> analise  : <<extend>>
grupo    ..> ct       : <<include>>
chat     ..> grupo    : <<include>>

@enduml