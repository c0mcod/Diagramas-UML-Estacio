@startuml

left to right direction
skinparam packageStyle rectangle

:Aluno: as aln
:Administração: as adm
:Secretaria: as sec
:Professor: as prof
:Coordenação: as coord


package Instituição {
    (Cadastro de disciplinas) as cd 
    (Cadastro de turmas) as ct
    (Cadastro de aluno) as ca
    (Cadastro de professores) as cp
    (Notificar alunos) as na
}

package AlunoInterface {
    (Abrir solicitação academica) as asa
    (Anexar documentos) as anxDoc
    (Verificar status de solicitação) as status
}

package Secretarianterface {
    (Validar documentos) as validDoc
    (Encaminhar solicitação) as encSol
}

package Coordenaçãonterface {
    (Aprovar solicitação) as aprovSol
    (Reprovar solicitação) as reprSol
}

package Professornterface {
    (Responder solicitações) as resSol
}

' =========================
' RELACIONAMENTOS
' =========================

adm --> ca
adm --> cp

coord --> cd
coord --> ct
coord --> na

sec --> na
sec --> validDoc
sec --> encSol

prof --> na
prof --> resSol

aln --> asa
aln --> anxDoc
aln --> status

coord --> aprovSol
coord --> reprSol

' =========================
' ALINHAMENTO VISUAL
' =========================


@enduml