@startuml diagramaClasse

class Pessoa {
    - nome : String
    - cpf : String
    - email : String
    - senhaHash : String
    - salt : String
    + login()
    + logout()
}

class Aluno {
    - matricula : String
    - curso : String
    + abrirSolicitacao()
    + acompanharSolicitacao()
}

class Professor {
    - siape : String
    - departamento : String
    + emitirParecer()
    + consultarSolicitacoesPorDisciplina()
}

class FuncionarioSecretaria {
    - matricula : String
    + receberSolicitacao()
    + validarDocumento()
    + encaminharSolicitacao()
}

class Coordenador {
    - curso : String
    + deferir()
    + indeferir()
    + consultarSolicitacoes()
    + acompanharIndicadores()
}

class Administrador {
    + gerenciarUsuarios()
    + gerenciarTiposSolicitacao()
    + configurarSistema()
}

class Role {
    - id : Long
    - nome : String
    - descricao : String
    + temPermissao()
}

class Permissao {
    - id : Long
    - nome : String
    - descricao : String
}

class Solicitacao {
    - id : Long
    - descricao : String
    - status : String
    - dataAbertura : LocalDate
    - dataAtualizacao : LocalDate
    + abrir()
    + cancelar()
    + atualizarStatus()
}

class TipoSolicitacao {
    - id : Long
    - nome : String
    - descricao : String
    - prazoEmDias : Integer
}

class Documento {
    - id : Long
    - nomeArquivo : String
    - caminho : String
    - dataUpload : LocalDate
    + upload()
    + remover()
}

class Disciplina {
    - id : Long
    - nome : String
    - codigo : String
    - cargaHoraria : Integer
}

class Turma {
    - id : Long
    - codigo : String
    - semestre : Integer
    - ano : Integer
}

class Parecer {
    - id : Long
    - descricao : String
    - decisao : String
    - dataEmissao : LocalDate
    + emitir()
}

class Notificacao {
    - id : Long
    - mensagem : String
    - lida : Boolean
    - dataEnvio : LocalDate
    + enviar()
    + marcarComoLida()
}

class HistoricoSolicitacao {
    - id : Long
    - statusAnterior : String
    - statusNovo : String
    - observacao : String
    - dataMovimentacao : LocalDate
}

' Herança
Pessoa <|-- Aluno
Pessoa <|-- Professor
Pessoa <|-- FuncionarioSecretaria
Pessoa <|-- Coordenador
Pessoa <|-- Administrador

' RBAC — Pessoa tem roles, roles tem permissões
Pessoa "0..*" --> "1..*" Role : possui
Role "1..*" --> "1..*" Permissao : concede

' subclasses -> Solicitacao
Aluno "1" --> "1..*" Solicitacao : faz
FuncionarioSecretaria "1" --> "0..*" Solicitacao : encaminha
Coordenador "1" --> "0..*" Solicitacao : decide
Professor "1" --> "0..*" Parecer : emite

' Solicitacao -> filhos
Solicitacao "1..*" --> "1" TipoSolicitacao : é do tipo
Solicitacao "1" o-- "0..*" Documento : anexa
Solicitacao "1" *-- "1..*" HistoricoSolicitacao : registra
Solicitacao "1" o-- "0..*" Parecer : recebe
Solicitacao "1" --> "0..*" Notificacao : gera

Notificacao "0..*" --> "1" Aluno : notifica
Parecer "0..*" --> "1" Disciplina : referente a
Disciplina "0..*" --> "0..*" Solicitacao : vinculada a

' Disciplina e Turma
Disciplina "1" o-- "0..*" Turma : oferece
Turma "1" o-- "0..*" Aluno : matriculado

' --------------------- ANOTAÇÕES -----------------------
note bottom of Professor : SIAPE é o número de matrícula\nfuncional de servidores públicos\nfederais no Brasil.
note right of Role : Exemplos de roles:\nALUNO, PROFESSOR,\nCOORDENADOR, ADMIN
note right of Permissao : Exemplos de permissões:\nABRIR_SOLICITACAO,\nDEFERIR, EMITIR_PARECER
note right of Pessoa : senhaHash: senha criptografada\nsalt: valor aleatório usado\nna criptografia da senha.

@enduml